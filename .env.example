# ─── VortexCMS 环境变量配置 ───────────────────────

# 服务器
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_MODE=debug
SERVER_BASE_URL=http://localhost:8080

# 数据库 (sqlite / postgres / mysql)
DB_DRIVER=sqlite
DB_NAME=vortexcms

# PostgreSQL 配置 (DB_DRIVER=postgres 时使用)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=vortexcms
# DB_PASSWORD=your-password
# DB_SSL_MODE=disable

# JWT 认证
JWT_SECRET=vortexcms-super-secret-key-change-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# 文件上传
UPLOAD_MAX_SIZE=20971520
UPLOAD_STORAGE_PATH=./uploads

# 限流 (每分钟请求数)
LIMITS_API_RATE=300

# 日志
LOG_LEVEL=info
