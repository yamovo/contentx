# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
APP_PORT=8080
HTTP_PORT=80
HTTPS_PORT=443
SERVER_MODE=debug
SERVER_BASE_URL=http://localhost:8080

# Database (sqlite, postgres, mysql)
DB_DRIVER=sqlite
DB_HOST=localhost
DB_PORT=5432
DB_USER=contentx
DB_PASSWORD=
DB_NAME=contentx
DB_SSL_MODE=disable

# JWT
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Redis (optional, for production blacklist/cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me
REDIS_DB=0
REDIS_PREFIX=contentx:

# Upload
UPLOAD_MAX_SIZE=10485760
UPLOAD_STORAGE_PATH=./uploads
UPLOAD_URL_PREFIX=/uploads
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf,video/mp4
UPLOAD_THUMBNAIL_MAX=400
UPLOAD_IMAGE_QUALITY=85

# Storage driver: "local" (default, inline disk logic) or "s3" (S3-compatible:
# AWS S3 / MinIO / Alibaba OSS). When set to "s3", the S3_* vars below are
# required; otherwise the server falls back to local disk with a warning.
STORAGE_DRIVER=local
S3_ENDPOINT=
S3_BUCKET=contentx
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Optional CDN/public URL override. If empty, derived from endpoint+bucket.
S3_PUBLIC_URL=
# Use HTTPS for S3 traffic (set to false for plain-HTTP MinIO on localhost).
S3_USE_SSL=true
# Use path-style addressing (true for MinIO; false for AWS S3 virtual-host style).
S3_PATH_STYLE=false

# Admin password (generated on first run if not set)
ADMIN_PASSWORD=

# Rate limiting
AUTH_RATE_LIMIT=10
API_RATE_LIMIT=100

# Log
LOG_LEVEL=info
LOG_FORMAT=json

# Metrics (Prometheus)
METRICS_ENABLED=true
METRICS_PATH=/metrics

# OpenTelemetry traces (OTLP/HTTP)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=contentx
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_TRACE_SAMPLE_RATIO=1.0

# Grafana (仅 docker-compose --profile monitor 时使用)
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Full-text search engine:
#   builtin     (default) in-memory inverted index with BM25 + CJK bigram
#   meilisearch external MeiliSearch (falls back to builtin if SDK unavailable)
#   noop        disable search entirely
SEARCH_ENGINE=builtin
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=
