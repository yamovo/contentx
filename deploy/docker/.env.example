# ContentX Environment Configuration
# Copy this file to .env and modify the values.

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_MODE=release
SERVER_BASE_URL=http://localhost:8080

# Database (postgres, mysql, sqlite)
DB_DRIVER=sqlite
DB_HOST=localhost
DB_PORT=5432
DB_USER=contentx
DB_PASSWORD=
DB_NAME=contentx
DB_SSL_MODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Upload
UPLOAD_MAX_SIZE=20971520
UPLOAD_STORAGE_PATH=./uploads
UPLOAD_URL_PREFIX=/uploads

# Cache
CACHE_DRIVER=memory
CACHE_DEFAULT_TTL=600s

# Queue
QUEUE_DRIVER=memory
QUEUE_MAX_WORKERS=4

# Logging
LOG_LEVEL=info
LOG_FORMAT=text
LOG_OUTPUT=stdout
